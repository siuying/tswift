{
  "name": "qswift-web-sandbox-prototype",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:wasm && astro dev --host 127.0.0.1 --port 4321",
    "start": "npm run dev",
    "build:wasm": "wasm-pack build ../../crates/qswift-wasm --target web --out-dir ../../prototype/web-sandbox/src/wasm --out-name qswift_wasm",
    "build": "npm run build:wasm && astro build",
    "test": "npm run build:wasm && node test/wasm-smoke.mjs",
    "preview": "wrangler pages dev ./dist --compatibility-date=2025-04-01",
    "deploy": "npm run build && wrangler pages deploy ./dist"
  },
  "dependencies": {
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "wasm-pack": "^0.15.0",
    "wrangler": "^4.83.0"
  }
}
