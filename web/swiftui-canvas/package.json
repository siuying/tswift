{
  "name": "@tswift/swiftui-canvas",
  "version": "0.0.0",
  "description": "Dependency-free Web Component host for tswift SwiftUI UIIR trees and patch streams.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./canvas": {
      "types": "./dist/canvas.d.ts",
      "import": "./dist/canvas.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "node scripts/validate.mjs",
    "dev": "vite example --host 127.0.0.1 --port 4322",
    "example": "npm run dev",
    "build:example": "vite build example",
    "test:snapshot": "playwright test",
    "test:snapshot:update": "playwright test --update-snapshots"
  },
  "keywords": [
    "swiftui",
    "web-component",
    "tswift",
    "uiir"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "typescript": "^5.5.0",
    "vite": "^7.0.0"
  }
}
