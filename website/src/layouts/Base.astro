---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'tswift — Swift Runtime in Rust',
  description = 'A lightweight Swift runtime written in Rust. Parse, type-check, and run Swift source without LLVM, Clang, or a Swift toolchain.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/assets/swift-icon-z.png" />
    <meta name="theme-color" content="#d9622e" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <!-- Mermaid (loaded only when needed via data-mermaid attribute) -->
  </head>
  <body>
    <Nav currentPath={Astro.url.pathname} />
    <slot />
    <Footer />
    <script type="module" is:inline>
      // Lazy-load Mermaid only when mermaid code blocks exist
      if (document.querySelector('.mermaid')) {
        const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
        mermaid.initialize({
          startOnLoad: true,
          theme: 'dark',
          fontFamily: '"IBM Plex Mono", ui-monospace, monospace',
          themeVariables: {
            darkMode: true,
            background: '#1a1c2b',
            mainBkg: '#262a40',
            primaryColor: '#262a40',
            primaryTextColor: '#eef0f6',
            primaryBorderColor: 'rgba(217,98,46,.6)',
            nodeBorder: 'rgba(217,98,46,.6)',
            nodeTextColor: '#eef0f6',
            lineColor: '#aab0c6',
            textColor: '#dfe3ee',
            edgeLabelBackground: '#262a40',
            secondaryColor: '#2f3350',
            tertiaryColor: '#262a40',
            tertiaryTextColor: '#eef0f6',
            fontSize: '14px',
          },
        });
        mermaid.run();
      }
    </script>
  </body>
</html>
