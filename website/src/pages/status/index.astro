---
import Doc from '../../layouts/Doc.astro';
import CoverageBar from '../../components/CoverageBar.astro';
import coverageIndex from '../../data/coverage/index.json';
import { parseLanguageTiers, sumTiers } from '../../lib/language-coverage';

const byFramework = Object.fromEntries(
  coverageIndex.frameworks.map((f) => [f.framework, f])
);
function pctInfo(totals: { implemented: number; partial: number; missing: number; total: number }) {
  const done = totals.implemented + totals.partial;
  const implementedPct = totals.total > 0 ? Math.round((totals.implemented / totals.total) * 100) : 0;
  const donePct = totals.total > 0 ? Math.round((done / totals.total) * 100) : 0;
  const tier = donePct >= 80 ? 'high' : donePct >= 50 ? 'mid' : donePct > 0 ? 'low' : 'zero';
  const label = totals.partial > 0 && donePct !== implementedPct ? `${implementedPct}%–${donePct}%` : `${implementedPct}%`;
  return { pct: donePct, implementedPct, tier, done, label };
}
const languageTiers = parseLanguageTiers();
const language = sumTiers(languageTiers, 0, 9);
const stdlib = byFramework.stdlib.totals;
const foundation = byFramework.foundation.totals;
const swiftui = byFramework.swiftui.totals;
const languagePct = pctInfo(language);
const stdlibPct = pctInfo(stdlib);
const foundationPct = pctInfo(foundation);
const swiftuiPct = pctInfo(swiftui);
// Hand-authored tier prose (kept short/curated), paired positionally with
// counts parsed from docs/swift-runtime/feature-checklist.md — numbers are
// never hand-typed, only the label text is.
const tierLabels = [
  'Tier 0 — Lexical &amp; Literals',
  'Tier 1 — Core Imperative (functions, control flow)',
  'Tier 2 — Value &amp; Nominal Types',
  'Tier 3 — Reference Types &amp; ARC',
  'Tier 4 — Protocols, Generics, Extensions',
  'Tier 5 — Error Handling',
  'Tier 6 — Advanced Types &amp; Expressions',
  'Tier 7 — Concurrency',
  'Tier 8 — Macros &amp; Metaprogramming',
  'Tier 9 — Attributes, Access Control, Operators',
];
---

<Doc title="Status Overview" section="status"
  description="Implementation status of the tswift Swift runtime — language features, stdlib, Foundation, and SwiftUI.">
  <h1>Implementation Status</h1>
  <p class="lead">
    tswift targets the full Swift 6.3 surface area. This dashboard tracks
    progress across language features, the standard library, Foundation, and SwiftUI.
  </p>

  <h2>At a glance</h2>

  <div class="status-grid" style="margin-bottom:3rem">
    <div class="status-card">
      <h3>Language</h3>
      <div class={`pct-big ${languagePct.tier}`}>{languagePct.label}</div>
      <p style="font-size:.85rem">Tiers 0–9 · {language.implemented} implemented · {language.partial} partial · {language.missing} missing (of {language.total})</p>
      <a href="/status/language" style="font-size:.85rem;font-weight:700">View details →</a>
    </div>
    <div class="status-card">
      <h3>Standard Library</h3>
      <div class={`pct-big ${stdlibPct.tier}`}>{stdlibPct.label}</div>
      <p style="font-size:.85rem">{stdlib.implemented} implemented · {stdlib.partial} partial · {stdlib.missing} missing (of {stdlib.total}) · hardened vs Apple tests</p>
      <a href="/status/stdlib" style="font-size:.85rem;font-weight:700">View details →</a>
    </div>
    <div class="status-card">
      <h3>Foundation</h3>
      <div class={`pct-big ${foundationPct.tier}`}>{foundationPct.label}</div>
      <p style="font-size:.85rem">{foundation.implemented} implemented · {foundation.partial} partial · {foundation.missing} missing (of {foundation.total}) · hardened vs real Swift</p>
      <a href="/status/foundation" style="font-size:.85rem;font-weight:700">View details →</a>
    </div>
    <div class="status-card">
      <h3>SwiftUI</h3>
      <div class={`pct-big ${swiftuiPct.tier}`}>{swiftuiPct.label}</div>
      <p style="font-size:.85rem">Tiers v1–5 + C1–C7 breadth · {swiftui.implemented} implemented · {swiftui.partial} partial · {swiftui.missing} missing (of {swiftui.total})</p>
      <a href="/status/swiftui" style="font-size:.85rem;font-weight:700">View details →</a>
    </div>
  </div>

  <h2>Language tiers</h2>
  <p>The Swift language surface is organised into tiers by complexity and dependency order.</p>

  {languageTiers.filter((t) => t.tier <= 9).map((t, i) => (
    <CoverageBar
      label={tierLabels[i]}
      implemented={t.totals.implemented}
      partial={t.totals.partial}
      total={t.totals.total}
      href="/status/language"
    />
  ))}

  <h2 style="margin-top:2rem">Roadmap</h2>
  <p>Implementation phases follow the runtime design plan (R0–R6+):</p>

  <div class="card-grid card-grid-2" style="margin-top:1.25rem">
    {[
      { phase: 'R0–R1', label: 'Literals, bindings, control flow, basic stdlib', done: true },
      { phase: 'R2',    label: 'Value types: struct, enum, optionals, properties', done: true },
      { phase: 'R3',    label: 'Reference types: class, ARC, closures', done: true },
      { phase: 'R4',    label: 'Protocols, generics, extensions, dispatch', done: true },
      { phase: 'R5',    label: 'Error handling, property wrappers, Codable, @main', done: true },
      { phase: 'R6',    label: 'Bytecode VM for performance (future)', done: false },
      { phase: 'R6+',   label: 'Concurrency ✓, Macros, SwiftUI, Ownership, Unsafe', done: false },
    ].map(({ phase, label, done }) => (
      <div class="card" style="display:flex;gap:1rem;align-items:flex-start">
        <span style={`font-size:1.4rem;flex-shrink:0;${done ? '' : 'opacity:.4'}`}>{done ? '✅' : '⏳'}</span>
        <div>
          <strong style="font-size:.85rem;color:var(--accent)">{phase}</strong>
          <p style="font-size:.875rem;margin-top:.25rem">{label}</p>
        </div>
      </div>
    ))}
  </div>
</Doc>
