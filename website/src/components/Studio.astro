---
// Web Studio — a focused mini-IDE for the tswift runtime: multi-file project,
// symbol outline, live SwiftUI canvas / console, inline diagnostics. All logic
// runs client-side; the pure project/module/outline transforms live in
// ../lib/studio/*.js (unit-tested in website/test/studio.mjs).
---

<div class="studio" id="studio">
  <!-- Top bar -->
  <header class="st-topbar">
    <div class="st-brand">
      <span class="st-dot"></span>
      <input id="st-project-name" class="st-project-name" aria-label="Project name" spellcheck="false" />
    </div>
    <div class="st-topbar-actions">
      <button id="st-quickopen-btn" class="st-btn st-btn-ghost" title="Quick open (⌘K)">⌘K Open…</button>
      <button id="st-new-btn" class="st-btn st-btn-ghost">New Project</button>
      <button id="st-run" class="st-btn st-btn-run" disabled>▶ Run</button>
      <span id="st-status" class="st-status">loading…</span>
    </div>
  </header>

  <div class="st-body">
    <!-- Sidebar: compact Files / Report / Symbols mode switcher -->
    <aside class="st-sidebar">
      <div class="st-mode-switcher" role="tablist" aria-label="Sidebar panels">
        <button type="button" role="tab" id="st-mode-files" class="st-mode-btn active"
          data-mode="files" aria-selected="true" aria-controls="st-panel-files" tabindex="0">Files</button>
        <button type="button" role="tab" id="st-mode-report" class="st-mode-btn"
          data-mode="report" aria-selected="false" aria-controls="st-panel-report" tabindex="-1">
          Report <span id="st-problem-count" class="st-badge">0</span></button>
        <button type="button" role="tab" id="st-mode-symbols" class="st-mode-btn"
          data-mode="symbols" aria-selected="false" aria-controls="st-panel-symbols" tabindex="-1">Symbols</button>
      </div>

      <div id="st-panel-files" class="st-panel st-files" role="tabpanel" aria-labelledby="st-mode-files">
        <div class="st-panel-head">
          <span>Files</span>
          <button id="st-add-file" class="st-icon-btn" title="New file">＋</button>
        </div>
        <ul id="st-file-tree" class="st-file-tree"></ul>
      </div>
      <div id="st-panel-report" class="st-panel st-report" role="tabpanel" aria-labelledby="st-mode-report" hidden>
        <ul id="st-problems" class="st-problems"><li class="st-empty">No problems.</li></ul>
      </div>
      <div id="st-panel-symbols" class="st-panel st-outline" role="tabpanel" aria-labelledby="st-mode-symbols" hidden>
        <ul id="st-outline" class="st-outline-tree"><li class="st-empty">—</li></ul>
      </div>
    </aside>

    <!-- Center: tabs + editor -->
    <main class="st-center">
      <div id="st-tabs" class="st-tabs" aria-label="Open files"></div>
      <div id="st-editor" class="st-editor"></div>
      <p id="st-editor-empty" class="st-editor-empty" hidden>No file open — choose a file in Files, or press ⌘K.</p>
    </main>

    <!-- Right: preview / console / problems -->
    <section class="st-right">
      <div class="st-right-tabs">
        <button data-rtab="preview" id="st-rtab-preview" class="st-rtab" style="display:none">Preview</button>
        <button data-rtab="console" class="st-rtab active">Console</button>
      </div>
      <div id="st-preview-wrap" class="st-preview" style="display:none">
        <div class="st-device"><div class="st-screen">
          <swiftui-canvas id="st-canvas" appearance="light" theme="ios"></swiftui-canvas>
        </div></div>
      </div>
      <pre id="st-console" class="st-console">Ready.</pre>
    </section>
  </div>

  <!-- Quick-open overlay -->
  <div id="st-quickopen" class="st-quickopen" hidden>
    <div class="st-quickopen-box">
      <input id="st-quickopen-input" class="st-quickopen-input" placeholder="Jump to a file or symbol…" spellcheck="false"
        role="combobox" aria-expanded="true" aria-autocomplete="list" aria-controls="st-quickopen-list" aria-label="Quick open" />
      <ul id="st-quickopen-list" class="st-quickopen-list" role="listbox"></ul>
    </div>
  </div>
</div>

<style>
  .studio {
    --st-chrome: #12131f;
    --st-panel: #1a1c2b;
    --st-line: rgba(255,255,255,.08);
    --st-text: #dfe4f2;
    --st-muted: #8b90a6;
    display: flex; flex-direction: column;
    height: min(78vh, 820px); min-height: 560px;
    border: 1px solid var(--border); border-radius: 12px; overflow: hidden;
    background: var(--st-chrome); color: var(--st-text);
    font-size: .85rem;
  }

  /* Top bar */
  .st-topbar {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: .55rem .85rem; background: var(--st-chrome);
    border-bottom: 1px solid var(--st-line); flex-shrink: 0;
  }
  .st-brand { display: flex; align-items: center; gap: .55rem; min-width: 0; }
  .st-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
  .st-project-name {
    background: transparent; border: 1px solid transparent; border-radius: 6px;
    color: var(--st-text); font-family: var(--font-mono); font-weight: 600;
    font-size: .9rem; padding: .2rem .4rem; width: 20ch; max-width: 40vw;
  }
  .st-project-name:hover { border-color: var(--st-line); }
  .st-project-name:focus { outline: none; border-color: var(--accent); background: var(--st-panel); }
  .st-topbar-actions { display: flex; align-items: center; gap: .5rem; }
  .st-btn {
    font-size: .78rem; font-weight: 600; padding: .35rem .7rem; border-radius: 7px;
    cursor: pointer; border: 1px solid var(--st-line); background: var(--st-panel); color: var(--st-text);
  }
  .st-btn:hover { border-color: var(--accent); }
  .st-btn-ghost { background: transparent; color: var(--st-muted); }
  .st-btn-run { background: var(--accent); border-color: transparent; color: #fff; }
  .st-btn-run:hover { background: var(--accent-strong); }
  .st-btn-run:disabled { opacity: .5; cursor: default; }
  .st-status { font-size: .72rem; color: var(--st-muted); font-family: var(--font-mono); min-width: 7ch; }
  .st-status.ok { color: #7ee0a8; }
  .st-status.error { color: #e0674f; }
  .st-status.running { color: var(--accent); }

  /* Body grid */
  .st-body { display: grid; grid-template-columns: 210px 1fr 340px; flex: 1; min-height: 0; }
  @media (max-width: 900px) { .st-body { grid-template-columns: 1fr; grid-auto-rows: minmax(180px, auto); } }

  .st-sidebar { border-right: 1px solid var(--st-line); display: flex; flex-direction: column; min-height: 0; background: var(--st-chrome); }

  .st-mode-switcher {
    display: flex; flex-shrink: 0; gap: 2px; padding: .3rem; border-bottom: 1px solid var(--st-line);
  }
  .st-mode-btn {
    flex: 1; display: flex; align-items: center; justify-content: center; gap: .3rem;
    padding: .35rem .3rem; border: none; border-radius: 6px; background: transparent;
    color: var(--st-muted); font-size: .7rem; font-weight: 700; letter-spacing: .03em;
    cursor: pointer; white-space: nowrap;
  }
  .st-mode-btn:hover { color: var(--st-text); background: rgba(255,255,255,.04); }
  .st-mode-btn.active { color: var(--st-text); background: var(--accent-soft); }
  .st-mode-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: -2px; }

  .st-panel { display: flex; flex-direction: column; min-height: 0; flex: 1; }
  .st-panel[hidden] { display: none; }
  .st-panel-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: .45rem .7rem; font-size: .68rem; font-weight: 700; letter-spacing: .1em;
    text-transform: uppercase; color: var(--st-muted); flex-shrink: 0;
  }
  .st-icon-btn { background: transparent; border: none; color: var(--st-muted); cursor: pointer; font-size: 1rem; line-height: 1; padding: 0 .25rem; }
  .st-icon-btn:hover { color: var(--accent); }

  .st-file-tree, .st-outline-tree, .st-problems { list-style: none; margin: 0; padding: 0 0 .5rem; overflow: auto; flex: 1; }
  .st-file-tree li { display: flex; align-items: center; gap: .2rem; padding: 0 .3rem; color: var(--st-text); }
  .st-file-tree li:hover { background: rgba(255,255,255,.04); }
  .st-file-tree li.active { background: var(--accent-soft); color: #fff; box-shadow: inset 2px 0 0 var(--accent); }
  .st-frow-open {
    display: flex; align-items: center; gap: .4rem; flex: 1; min-width: 0;
    padding: .25rem .4rem; background: transparent; border: none; color: inherit;
    font: inherit; text-align: left; cursor: pointer; border-radius: 4px;
  }
  .st-file-tree .st-fname { flex: 1; font-family: var(--font-mono); font-size: .78rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .st-file-tree .st-ficon { color: var(--st-muted); font-size: .7rem; }
  .st-file-tree .st-frow-actions { display: flex; gap: .2rem; opacity: 0; pointer-events: none; flex-shrink: 0; }
  .st-file-tree li:hover .st-frow-actions,
  .st-file-tree li:focus-within .st-frow-actions { opacity: 1; pointer-events: auto; }
  .st-frow-actions button { background: transparent; border: none; color: var(--st-muted); cursor: pointer; font-size: .72rem; padding: .2rem; border-radius: 4px; }
  .st-frow-actions button:hover { color: var(--accent); }

  .st-frow-open:focus-visible,
  .st-frow-actions button:focus-visible,
  .st-sym-row:focus-visible,
  .st-prob-row:focus-visible,
  .st-qo-row:focus-visible {
    outline: 2px solid var(--accent); outline-offset: -2px;
  }

  .st-sym-row, .st-prob-row {
    display: block; width: 100%; text-align: left; background: transparent; border: none;
    color: inherit; font: inherit; cursor: pointer; padding: 0;
  }
  .st-outline-tree li { padding: 0; font-family: var(--font-mono); font-size: .76rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .st-outline-tree .st-sym-row { padding: .2rem .7rem; }
  .st-outline-tree li:hover { background: rgba(255,255,255,.04); }
  .st-outline-tree .st-sym-child .st-sym-row { padding-left: 1.6rem; }
  .st-outline-tree .st-sym-file { color: var(--st-muted); font-size: .66rem; text-transform: uppercase; letter-spacing: .08em; padding-top: .4rem; padding-left: .7rem; cursor: default; font-family: var(--font-sans); }
  .st-sym-kind { color: var(--accent); opacity: .8; }
  .st-empty { color: var(--st-muted); font-style: italic; padding: .5rem .7rem; }

  /* Center */
  .st-center { display: flex; flex-direction: column; min-width: 0; min-height: 0; background: var(--st-panel); position: relative; }
  .st-tabs { display: flex; overflow-x: auto; border-bottom: 1px solid var(--st-line); flex-shrink: 0; background: var(--st-chrome); }
  .st-tab {
    display: flex; align-items: center; font-family: var(--font-mono); font-size: .76rem; color: var(--st-muted);
    border-right: 1px solid var(--st-line); white-space: nowrap; flex-shrink: 0;
  }
  .st-tab.active { color: var(--st-text); background: var(--st-panel); box-shadow: inset 0 -2px 0 var(--accent); }
  .st-tab-open {
    display: flex; align-items: center; gap: .4rem; padding: .45rem .3rem .45rem .8rem; cursor: pointer;
    font: inherit; color: inherit; background: transparent; border: none;
  }
  .st-tab .st-tab-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); visibility: hidden; }
  .st-tab.dirty .st-tab-dot { visibility: visible; }
  .st-tab-close {
    display: flex; align-items: center; justify-content: center; width: 1.2rem; height: 1.2rem; margin-right: .4rem;
    padding: 0; cursor: pointer; font-size: .85rem; line-height: 1; color: var(--st-muted); background: transparent;
    border: none; border-radius: 3px;
  }
  .st-tab-close:hover, .st-tab-close:focus-visible { color: var(--st-text); background: rgba(255,255,255,.08); }
  .st-editor { flex: 1; min-height: 0; overflow: hidden; }
  .st-editor .cm-editor { height: 100%; }
  .st-editor-empty {
    position: absolute; inset: 2.6rem 0 0 0; margin: 0; display: flex; align-items: center; justify-content: center;
    color: var(--st-muted); font-size: .82rem; background: var(--st-panel); text-align: center; padding: 1rem;
  }

  /* Right */
  .st-right { border-left: 1px solid var(--st-line); display: flex; flex-direction: column; min-height: 0; background: var(--st-chrome); }
  .st-right-tabs { display: flex; border-bottom: 1px solid var(--st-line); flex-shrink: 0; }
  .st-rtab { padding: .5rem .8rem; cursor: pointer; font-size: .74rem; font-weight: 600; color: var(--st-muted); background: transparent; border: none; }
  .st-rtab.active { color: var(--st-text); box-shadow: inset 0 -2px 0 var(--accent); }
  .st-badge { background: var(--st-line); border-radius: 999px; padding: 0 .4rem; font-size: .66rem; }
  .st-badge.has { background: var(--accent); color: #fff; }
  .st-console { flex: 1; margin: 0; padding: .8rem; overflow: auto; font-family: var(--font-mono); font-size: .78rem; white-space: pre-wrap; color: var(--st-text); }
  .st-console.error { color: #e0674f; }
  .st-problems { flex: 1; }
  .st-problems li { padding: 0; font-size: .76rem; border-bottom: 1px solid var(--st-line); }
  .st-problems li:hover { background: rgba(255,255,255,.04); }
  .st-problems .st-prob-row { display: flex; gap: .5rem; align-items: baseline; padding: .4rem .7rem; }
  .st-problems .st-prob-loc { font-family: var(--font-mono); color: var(--st-muted); font-size: .7rem; flex-shrink: 0; }
  .st-problems .st-prob-error { color: #e0674f; }
  .st-problems .st-prob-warning { color: #d9a85f; }

  .st-preview { flex: 1; display: flex; align-items: flex-start; justify-content: center; padding: 1rem; overflow: auto; background: #0d1117; }
  .st-device { width: 300px; max-width: 100%; border: 9px solid #1c1c1e; border-radius: 34px; background: #000; box-shadow: 0 12px 40px rgba(0,0,0,.35); overflow: hidden; }
  .st-screen { background: #fff; border-radius: 25px; overflow: hidden; min-height: 380px; display: flex; flex-direction: column; }
  .st-screen swiftui-canvas { display: block; flex: 1; }

  /* Quick-open */
  .st-quickopen { position: fixed; inset: 0; background: rgba(0,0,0,.45); display: flex; align-items: flex-start; justify-content: center; padding-top: 12vh; z-index: 50; }
  .st-quickopen[hidden] { display: none; }
  .st-quickopen-box { width: min(560px, 92vw); background: var(--st-panel); border: 1px solid var(--st-line); border-radius: 12px; overflow: hidden; box-shadow: 0 24px 60px rgba(0,0,0,.5); }
  .st-quickopen-input { width: 100%; padding: .9rem 1rem; background: transparent; border: none; border-bottom: 1px solid var(--st-line); color: var(--st-text); font-size: 1rem; font-family: var(--font-mono); }
  .st-quickopen-input:focus { outline: none; }
  .st-quickopen-list { list-style: none; margin: 0; padding: .3rem; max-height: 50vh; overflow: auto; }
  .st-quickopen-list li { padding: 0; border-radius: 7px; }
  .st-quickopen-list li.sel { background: var(--accent-soft); box-shadow: inset 2px 0 0 var(--accent); }
  .st-quickopen-list .st-qo-row {
    display: flex; width: 100%; align-items: baseline; gap: .6rem; padding: .5rem .7rem;
    border-radius: 7px; cursor: pointer; background: transparent; border: none; color: inherit; font: inherit; text-align: left;
  }
  .st-quickopen-list .st-qo-label { font-family: var(--font-mono); font-size: .84rem; color: var(--st-text); }
  .st-quickopen-list .st-qo-detail { font-size: .72rem; color: var(--st-muted); margin-left: auto; }
  .st-quickopen-list .st-qo-type { font-size: .64rem; text-transform: uppercase; letter-spacing: .06em; color: var(--accent); min-width: 3.5ch; }
</style>

<script type="module">
  import '../../../web/swiftui-canvas/src/canvas.ts';
  import { createStudioEditor } from '../lib/studio/editor.js';
  import * as store from '../lib/studio/project.js';
  import { moduleJson, isSwiftUIProject } from '../lib/studio/module.js';
  import { buildOutline, quickOpenIndex, filterEntries } from '../lib/studio/outline.js';
  import { applySidebarMode, nextSidebarMode } from '../lib/studio/sidebar-mode.js';
  import { SAMPLES, sampleById } from '../lib/studio/samples.js';
  import {
    emptyTabs,
    openTab,
    closeTab,
    renameTab,
    sanitizeTabs,
    serializeTabs,
    deserializeTabs,
    TABS_STORAGE_KEY,
  } from '../lib/studio/tabs.js';

  // ── State ────────────────────────────────────────────────────────
  // localStorage can throw (SecurityError in a private/embedded/blocked-storage
  // context, or a QuotaExceededError on write) — guard every read/write and
  // degrade to the starter project + in-memory-only persistence rather than
  // aborting boot.
  function readStoredProject() {
    try {
      return store.deserialize(localStorage.getItem(store.STORAGE_KEY));
    } catch {
      return null;
    }
  }
  let storageAvailable = true;
  let project = readStoredProject()
    || store.createProject(SAMPLES[0].name, SAMPLES[0].files);
  let symbols = [];
  let diagnosticsByFile = new Map(); // path -> [{line,col,severity,message}]

  // Explicit open/close tab state: which files have a tab (a subset of
  // `project.files`) and which one is active. Restored from its own
  // localStorage slot and sanitized against the loaded project so a
  // stale/tampered/renamed id can never point at a missing file.
  function readStoredTabs(validPaths) {
    try {
      return deserializeTabs(localStorage.getItem(TABS_STORAGE_KEY), validPaths);
    } catch {
      return null;
    }
  }
  // A persisted strip may be `null` (nothing saved, or corrupt/wrong-version
  // data — `deserializeTabs` never throws, it just says "don't trust this")
  // or a *valid* object whose `activePath` is legitimately `null` (the user
  // closed their last tab and that closed state was saved as-is). Only the
  // former should fall back to opening the project's active file; the
  // latter must be preserved verbatim so a reload doesn't resurrect a tab
  // the user deliberately closed.
  const projectPaths = project.files.map((f) => f.path);
  let tabs = readStoredTabs(projectPaths) || openTab(emptyTabs(), project.activePath);

  // wasm exports (filled by initWasm)
  let runSwiftModule = null, listSymbols = null, swiftUICompileModule = null,
      swiftUIDispatch = null, swiftDiagnosticsModule = null;

  // ── DOM ──────────────────────────────────────────────────────────
  const $ = (id) => document.getElementById(id);
  const nameInput = $('st-project-name');
  const fileTree  = $('st-file-tree');
  const outlineEl = $('st-outline');
  const tabsEl    = $('st-tabs');
  const runBtn    = $('st-run');
  const statusEl  = $('st-status');
  const consoleEl = $('st-console');
  const problemsEl = $('st-problems');
  const problemCount = $('st-problem-count');
  const previewWrap = $('st-preview-wrap');
  const canvas    = $('st-canvas');
  const rtabs     = document.querySelectorAll('.st-rtab');
  const modeBtns  = document.querySelectorAll('.st-mode-btn');
  const modePanels = { files: $('st-panel-files'), report: $('st-panel-report'), symbols: $('st-panel-symbols') };

  const editorEl = $('st-editor');
  const editorEmptyEl = $('st-editor-empty');

  const editor = createStudioEditor({
    parent: editorEl,
    getDiagnostics: () => diagnosticsByFile.get(tabs.activePath) || [],
    onInput: onEditorInput,
    onRun: () => runBtn.click(),
    onSave: save,
  });

  function setStatus(type, text) { statusEl.textContent = text; statusEl.className = `st-status ${type}`; }

  // ── Persistence ──────────────────────────────────────────────────
  let saveTimer = null;
  function save() {
    if (!storageAvailable) return;
    try {
      localStorage.setItem(store.STORAGE_KEY, store.serialize(project));
      localStorage.setItem(TABS_STORAGE_KEY, serializeTabs(tabs));
    } catch {
      // Blocked/quota-exceeded storage: keep working in-memory, stop retrying.
      storageAvailable = false;
    }
  }
  function scheduleSave() { clearTimeout(saveTimer); saveTimer = setTimeout(save, 400); }

  // ── Rendering ────────────────────────────────────────────────────
  function renderName() { nameInput.value = project.name; }

  function renderFileTree() {
    fileTree.innerHTML = '';
    for (const f of store.sortFiles(project.files)) {
      const li = document.createElement('li');
      if (f.path === tabs.activePath) li.classList.add('active');
      const manifest = store.isManifest(f.path);
      li.innerHTML = `<button type="button" class="st-frow-open" aria-current="${f.path === tabs.activePath ? 'true' : 'false'}">` +
        `<span class="st-ficon" aria-hidden="true">${manifest ? '📦' : 'ƒ'}</span>` +
        `<span class="st-fname">${escapeHtml(f.path)}</span></button>` +
        `<span class="st-frow-actions">` +
        `<button type="button" data-act="rename" title="Rename" aria-label="Rename ${escapeHtml(f.path)}">✎</button>` +
        `<button type="button" data-act="delete" title="Delete" aria-label="Delete ${escapeHtml(f.path)}">🗑</button></span>`;
      const openBtn = li.querySelector('.st-frow-open');
      openBtn.addEventListener('click', () => openFile(f.path));
      openBtn.addEventListener('keydown', (e) => {
        if (e.key === 'F2') { e.preventDefault(); renameFilePrompt(f.path); }
        else if (e.key === 'Delete' || e.key === 'Backspace') { e.preventDefault(); deleteFilePrompt(f.path); }
      });
      li.querySelector('[data-act="rename"]').addEventListener('click', (e) => { e.stopPropagation(); renameFilePrompt(f.path); });
      li.querySelector('[data-act="delete"]').addEventListener('click', (e) => { e.stopPropagation(); deleteFilePrompt(f.path); });
      fileTree.appendChild(li);
    }
  }

  function renderTabs() {
    tabsEl.innerHTML = '';
    for (const path of tabs.openPaths) {
      const file = project.files.find((f) => f.path === path);
      if (!file) continue; // defensive: sanitizeTabs already keeps this in sync
      const wrap = document.createElement('span');
      wrap.className = 'st-tab' + (path === tabs.activePath ? ' active' : '');
      wrap.innerHTML = `<button type="button" class="st-tab-open" aria-current="${path === tabs.activePath ? 'true' : 'false'}">` +
        `<span class="st-tab-dot"></span>${escapeHtml(store.basename(path))}</button>` +
        `<button type="button" class="st-tab-close" title="Close" aria-label="Close ${escapeHtml(store.basename(path))}">\u00d7</button>`;
      wrap.querySelector('.st-tab-open').addEventListener('click', () => openFile(path));
      wrap.querySelector('.st-tab-close').addEventListener('click', (e) => { e.stopPropagation(); closeFile(path); });
      tabsEl.appendChild(wrap);
    }
    updateEditorVisibility();
  }

  // Keep the editor pane's visibility (and its accessible "no file open"
  // placeholder) in lockstep with `tabs.activePath`. Closing the last tab
  // must not leave the CodeMirror content editable region mounted and
  // reachable by Tab/AT while showing stale text underneath the placeholder
  // — `hidden` fully removes it from the layout, tab order, and a11y tree
  // (same mechanism `editorEmptyEl` already used), while `editor.js` keeps
  // each file's `EditorState` cached regardless of DOM visibility, so
  // reopening a tab later restores its content untouched.
  function updateEditorVisibility() {
    const empty = tabs.activePath === null;
    editorEl.hidden = empty;
    editorEmptyEl.hidden = !empty;
  }

  function renderOutline() {
    outlineEl.innerHTML = '';
    const groups = buildOutline(symbols);
    if (groups.length === 0) { outlineEl.innerHTML = '<li class="st-empty">No symbols yet.</li>'; return; }
    for (const g of groups) {
      const head = document.createElement('li');
      head.className = 'st-sym-file';
      head.textContent = store.basename(g.file);
      outlineEl.appendChild(head);
      for (const root of g.roots) {
        outlineEl.appendChild(symbolRow(root, false));
        for (const child of root.children) outlineEl.appendChild(symbolRow(child, true));
      }
    }
  }

  function symbolRow(sym, child) {
    const li = document.createElement('li');
    if (child) li.classList.add('st-sym-child');
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'st-sym-row';
    btn.innerHTML = `<span class="st-sym-kind" aria-hidden="true">${sym.kind}</span> ${escapeHtml(sym.name)}`;
    btn.title = sym.signature || sym.name;
    btn.setAttribute('aria-label', `${sym.kind} ${sym.name}, ${store.basename(sym.file)} line ${sym.line}`);
    btn.addEventListener('click', () => jumpTo(sym.file, sym.line));
    li.appendChild(btn);
    return li;
  }

  function renderProblems() {
    const items = [];
    for (const [file, diags] of diagnosticsByFile) {
      for (const d of diags) items.push({ file, ...d });
    }
    items.sort((a, b) => (a.severity === b.severity ? 0 : a.severity === 'error' ? -1 : 1));
    problemCount.textContent = String(items.length);
    problemCount.classList.toggle('has', items.length > 0);
    if (items.length === 0) { problemsEl.innerHTML = '<li class="st-empty">No problems.</li>'; return; }
    problemsEl.innerHTML = '';
    for (const it of items) {
      const li = document.createElement('li');
      li.innerHTML = `<button type="button" class="st-prob-row" aria-label="${it.severity} in ${escapeHtml(store.basename(it.file))} line ${it.line}: ${escapeHtml(it.message)}">` +
        `<span class="st-prob-loc st-prob-${it.severity}">${escapeHtml(store.basename(it.file))}:${it.line}</span>` +
        `<span>${escapeHtml(it.message)}</span></button>`;
      li.querySelector('.st-prob-row').addEventListener('click', () => jumpTo(it.file, it.line));
      problemsEl.appendChild(li);
    }
  }

  // ── File actions ─────────────────────────────────────────────────
  // Sync the editor pane + project's notion of "current file" to `tabs`
  // (the single source of truth for what's open/active), including the
  // honest empty state when the last tab has been closed.
  //
  // This is the ONE ownership seam that reconciles the three views of "which
  // file is active": `tabs` (deterministic neighbor selection on close),
  // `project.activePath` (whatever `project.js` last picked — e.g. the first
  // file after a delete), and the editor. After any mutation, callers run
  // `reconcileTabs()` to settle `tabs`, then this seam makes
  // `project.activePath` follow `tabs` so persistence and diagnostics (which
  // key off `project.activePath`) can never disagree with what's on screen.
  // Mutation handlers must route through here rather than calling
  // `editor.open()` directly, which would bypass the reconciliation.
  function syncEditorToTabs() {
    if (tabs.activePath) {
      project = { ...project, activePath: tabs.activePath };
      editor.open(tabs.activePath, store.fileSource(project, tabs.activePath) ?? '');
    } else {
      // Closing the last tab must not strand `project.activePath` on the
      // now-untabbed file it last pointed at — that split-brain (tabs says
      // "nothing open", project says "X is active") is exactly what this
      // seam exists to prevent. `''` is project.js's own canonical empty
      // (see `createProject`), and `deserialize` already treats any
      // non-matching `activePath` as "pick files[0]", so persisting `''`
      // round-trips safely through save/reload without special-casing.
      project = { ...project, activePath: '' };
    }
    updateEditorVisibility();
  }

  function openFile(path) {
    if (!project.files.some((f) => f.path === path)) return;
    tabs = openTab(tabs, path);
    syncEditorToTabs();
    renderFileTree(); renderTabs();
    scheduleSave();
  }

  function closeFile(path) {
    tabs = closeTab(tabs, path);
    syncEditorToTabs();
    renderFileTree(); renderTabs();
    scheduleSave();
  }

  // Reconcile `tabs` against the current project file list (call after any
  // add/rename/delete/reload) and, by default, guarantee something is
  // open+editable afterwards — closing the *last* tab is the only path
  // allowed to reach the honest empty state; structural project edits never
  // should. Boot-time restore is the one caller that passes
  // `{ allowEmpty: true }`: sanitizing a persisted strip can validly land on
  // `activePath: null` because the user closed their last tab before
  // reloading, and that deliberate choice must survive the reload rather
  // than being silently overridden.
  function reconcileTabs({ allowEmpty = false } = {}) {
    tabs = sanitizeTabs(tabs, project.files.map((f) => f.path));
    if (!tabs.activePath && !allowEmpty) {
      // `project.activePath` may itself be the canonical empty `''` (the
      // last tab was closed before this structural edit ran) — fall back to
      // the first file rather than opening a bogus `''` tab.
      const fallback = project.activePath || project.files[0]?.path;
      if (fallback) tabs = openTab(tabs, fallback);
    }
  }

  function onEditorInput() {
    if (!tabs.activePath) return; // no file backing the editor right now
    project = store.updateSource(project, tabs.activePath, editor.value);
    scheduleSave();
    scheduleAnalyze();
  }

  function addFilePrompt() {
    const name = prompt('New file name (e.g. Model.swift):', 'NewFile.swift');
    if (!name) return;
    const err = store.validatePath(project, name.trim());
    if (err) { alert(err); return; }
    project = store.addFile(project, name.trim(), '');
    tabs = openTab(tabs, project.activePath);
    syncEditorToTabs();
    renderAll(); save(); scheduleAnalyze();
  }

  function renameFilePrompt(path) {
    const next = prompt('Rename file:', path);
    if (!next || next.trim() === path) return;
    try {
      editor.forget(path);
      project = store.renameFile(project, path, next.trim());
      tabs = renameTab(tabs, path, next.trim());
      reconcileTabs();
      syncEditorToTabs();
      renderAll(); save(); scheduleAnalyze();
    } catch (e) { alert(e.message); }
  }

  function deleteFilePrompt(path) {
    if (!confirm(`Delete ${path}?`)) return;
    try {
      project = store.deleteFile(project, path);
      editor.forget(path);
      tabs = closeTab(tabs, path);
      reconcileTabs();
      syncEditorToTabs();
      renderAll(); save(); scheduleAnalyze();
    } catch (e) { alert(e.message); }
  }

  nameInput.addEventListener('input', () => { project = { ...project, name: nameInput.value }; scheduleSave(); });
  $('st-add-file').addEventListener('click', addFilePrompt);

  // ── New project ──────────────────────────────────────────────────
  $('st-new-btn').addEventListener('click', () => {
    const list = SAMPLES.map((s, i) => `${i + 1}. ${s.name} — ${s.description}`).join('\n');
    const pick = prompt(`Start a new project from a template:\n\n${list}\n\nEnter a number (1–${SAMPLES.length}):`, '1');
    if (!pick) return;
    const idx = parseInt(pick, 10) - 1;
    const sample = SAMPLES[idx] || SAMPLES[0];
    for (const f of project.files) editor.forget(f.path);
    project = store.createProject(sample.name, sample.files);
    tabs = openTab(emptyTabs(), project.activePath);
    syncEditorToTabs();
    renderAll(); save(); scheduleAnalyze();
  });

  // ── Jump / goto ──────────────────────────────────────────────────
  function jumpTo(file, line) {
    if (file !== tabs.activePath) openFile(file);
    editor.gotoLine(line);
    showRightTab('console'); // keep code visible; don't steal focus to preview
  }

  // ── Right tabs ───────────────────────────────────────────────────
  function showRightTab(name) {
    previewWrap.style.display = name === 'preview' ? 'flex' : 'none';
    consoleEl.style.display = name === 'console' ? '' : 'none';
    rtabs.forEach((t) => t.classList.toggle('active', t.dataset.rtab === name));
  }
  rtabs.forEach((t) => t.addEventListener('click', () => showRightTab(t.dataset.rtab)));
  function setPreviewAvailable(on) {
    $('st-rtab-preview').style.display = on ? '' : 'none';
    if (!on && $('st-rtab-preview').classList.contains('active')) showRightTab('console');
  }

  // ── Sidebar mode switcher (Files / Report / Symbols) ──────────────
  // State machine + keyboard nav live in ../lib/studio/sidebar-mode.js so the
  // production behavior is exercised by the unit test, not re-implemented.
  function showSidebarMode(mode) {
    applySidebarMode(mode, { panels: modePanels, buttons: modeBtns });
  }
  modeBtns.forEach((b) => b.addEventListener('click', () => { showSidebarMode(b.dataset.mode); b.focus(); }));
  document.querySelector('.st-mode-switcher').addEventListener('keydown', (e) => {
    const next = nextSidebarMode(document.activeElement?.dataset?.mode, e.key);
    if (next) {
      e.preventDefault();
      showSidebarMode(next);
      $(`st-mode-${next}`).focus();
    }
  });

  // ── Analyze (diagnostics + symbols), debounced ───────────────────
  let analyzeTimer = null;
  function scheduleAnalyze() { clearTimeout(analyzeTimer); analyzeTimer = setTimeout(analyze, 350); }
  function analyze() {
    if (!swiftDiagnosticsModule || !listSymbols) return;
    const json = moduleJson(project);
    try {
      const diag = JSON.parse(swiftDiagnosticsModule(json));
      diagnosticsByFile = new Map();
      for (const d of diag.diagnostics || []) {
        const file = d.file || project.activePath;
        if (!diagnosticsByFile.has(file)) diagnosticsByFile.set(file, []);
        diagnosticsByFile.get(file).push(d);
      }
    } catch { diagnosticsByFile = new Map(); }
    try {
      const sym = JSON.parse(listSymbols(json));
      symbols = sym.ok ? sym.symbols : [];
    } catch { symbols = []; }
    renderOutline(); renderProblems();
    editor.refreshDiagnostics(); // push the latest diagnostics into the CM6 lint state
  }

  // ── Run ──────────────────────────────────────────────────────────
  canvas.addEventListener('swiftui-event', (e) => {
    if (!swiftUIDispatch) return;
    const { id, event, value } = e.detail;
    const payload = value == null ? '' : JSON.stringify(value);
    try {
      const res = JSON.parse(swiftUIDispatch(id, event, payload));
      if (res.ok) { canvas.applyPatches(res.patches); return; }
      reportEventFailure('event error', res.error || 'SwiftUI event dispatch failed.');
    } catch (err) {
      reportEventFailure('event crash', String(err.message || err));
    }
  });
  // A SwiftUI event-dispatch or runtime failure must surface diagnostics on
  // Report just like a Run failure does, not silently sit in the status pill.
  function reportEventFailure(status, message) {
    consoleEl.textContent = message;
    consoleEl.className = 'st-console error';
    setStatus('error', status);
    showRightTab('console');
    showSidebarMode('report');
  }

  runBtn.addEventListener('click', () => {
    if (!runSwiftModule) return;
    setStatus('running', 'running…');
    const json = moduleJson(project);
    if (isSwiftUIProject(project)) {
      let res;
      try { res = JSON.parse(swiftUICompileModule(json)); } catch (err) { res = { ok: false, error: String(err) }; }
      if (res.ok && res.root) {
        canvas.mount(res.tree);
        setPreviewAvailable(true);
        showRightTab('preview');
        setStatus('ok', `preview · ${res.root}`);
        return;
      }
      // SwiftUI compile failed — fall through to show the error in console.
      consoleEl.textContent = res.error || 'SwiftUI compile failed.';
      consoleEl.className = 'st-console error';
      setPreviewAvailable(false);
      showRightTab('console');
      showSidebarMode('report');
      setStatus('error', 'compile error');
      return;
    }
    setPreviewAvailable(false);
    try {
      const result = JSON.parse(runSwiftModule(json));
      if (result.run) {
        const out = [result.run.stdout?.trim(), result.run.stderr?.trim()].filter(Boolean).join('\n');
        consoleEl.textContent = out || '(no output)';
        consoleEl.className = result.run.ok ? 'st-console' : 'st-console error';
        setStatus(result.run.ok ? 'ok' : 'error', `${result.run.ok ? 'ok' : 'failed'} (${result.run.elapsedMs}ms)`);
        if (!result.run.ok) {
          showRightTab('console');
          showSidebarMode('report');
        }
      } else {
        const msg = result.compile?.stderr || 'Compile failed.';
        consoleEl.textContent = msg;
        consoleEl.className = 'st-console error';
        setStatus('error', 'compile error');
        showRightTab('console');
        showSidebarMode('report');
      }
    } catch (err) {
      consoleEl.textContent = String(err.message || err);
      consoleEl.className = 'st-console error';
      setStatus('error', 'error');
      showRightTab('console');
      showSidebarMode('report');
    }
  });

  // ── Quick open (⌘K) ──────────────────────────────────────────────
  const qo = $('st-quickopen'), qoInput = $('st-quickopen-input'), qoList = $('st-quickopen-list');
  let qoEntries = [], qoSelected = 0;
  function openQuickOpen() {
    qoEntries = quickOpenIndex(project, symbols);
    qoInput.value = ''; qoSelected = 0;
    renderQuickOpen('');
    qo.hidden = false; qoInput.focus();
  }
  function closeQuickOpen() { qo.hidden = true; editor.focus(); }
  function renderQuickOpen(query) {
    const results = filterEntries(qoEntries, query);
    qoList.innerHTML = '';
    if (qoSelected >= results.length) qoSelected = Math.max(0, results.length - 1);
    results.forEach((e, i) => {
      const li = document.createElement('li');
      li.id = `st-qo-opt-${i}`;
      li.setAttribute('role', 'option');
      const selected = i === qoSelected;
      li.setAttribute('aria-selected', selected ? 'true' : 'false');
      if (selected) li.classList.add('sel');
      li.innerHTML = `<button type="button" class="st-qo-row" tabindex="-1">` +
        `<span class="st-qo-type" aria-hidden="true">${e.type === 'file' ? 'file' : (e.kind || 'sym')}</span>` +
        `<span class="st-qo-label">${escapeHtml(e.label)}</span>` +
        `<span class="st-qo-detail">${escapeHtml(e.detail)}</span></button>`;
      li.querySelector('.st-qo-row').addEventListener('click', () => { jumpTo(e.file, e.line); closeQuickOpen(); });
      qoList.appendChild(li);
    });
    qo._results = results;
    qoInput.setAttribute('aria-activedescendant', results.length ? `st-qo-opt-${qoSelected}` : '');
  }
  qoInput.addEventListener('input', () => { qoSelected = 0; renderQuickOpen(qoInput.value); });
  qoInput.addEventListener('keydown', (e) => {
    const results = qo._results || [];
    if (e.key === 'ArrowDown') { qoSelected = Math.min(qoSelected + 1, results.length - 1); renderQuickOpen(qoInput.value); e.preventDefault(); }
    else if (e.key === 'ArrowUp') { qoSelected = Math.max(qoSelected - 1, 0); renderQuickOpen(qoInput.value); e.preventDefault(); }
    else if (e.key === 'Enter') { const r = results[qoSelected]; if (r) { jumpTo(r.file, r.line); closeQuickOpen(); } }
    else if (e.key === 'Escape') closeQuickOpen();
  });
  qo.addEventListener('click', (e) => { if (e.target === qo) closeQuickOpen(); });
  $('st-quickopen-btn').addEventListener('click', openQuickOpen);
  window.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') { e.preventDefault(); openQuickOpen(); }
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 's') { e.preventDefault(); save(); }
    if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') { e.preventDefault(); runBtn.click(); }
  });

  // ── Helpers / boot ───────────────────────────────────────────────
  function escapeHtml(s) { return String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c])); }
  function renderAll() { renderName(); renderFileTree(); renderTabs(); renderOutline(); renderProblems(); }

  reconcileTabs({ allowEmpty: true });
  renderAll();
  syncEditorToTabs();

  async function initWasm() {
    try {
      const { installTSwiftHostServices } = await import('../lib/tswift-host-services.js');
      installTSwiftHostServices();
      const dbInstallPromise = import('../lib/tswift-db-host-service.js')
        .then((m) => m.installTSwiftDbHostService())
        .catch(() => false);
      const base = import.meta.env.BASE_URL || '/';
      const wasmUrl = new URL(base + 'wasm/tswift_wasm.js', location.origin).href;
      const importModule = new Function('u', 'return import(u)');
      const mod = await importModule(wasmUrl);
      await mod.default();
      runSwiftModule = mod.runSwiftModule;
      listSymbols = mod.listSymbols;
      swiftUICompileModule = mod.swiftUICompileModule;
      swiftUIDispatch = mod.swiftUIDispatch;
      swiftDiagnosticsModule = mod.swiftDiagnosticsModule;
      await dbInstallPromise;
      runBtn.disabled = false;
      setStatus('', 'idle');
      analyze();
    } catch (err) {
      setStatus('error', 'wasm failed');
      consoleEl.textContent = `Failed to load runtime:\n${err.message}`;
      consoleEl.className = 'st-console error';
    }
  }
  initWasm();
</script>
