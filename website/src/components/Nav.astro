---
interface Props {
  currentPath?: string;
}
const { currentPath = '/' } = Astro.props;

function isActive(prefix: string) {
  return currentPath === prefix || currentPath.startsWith(prefix + '/');
}
---

<nav class="site-nav" aria-label="Site navigation">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="tswift home">
      <img class="logo-bird" src="/assets/swift-icon-z.png" alt="" width="26" height="26" />
      <span>tswift</span>
    </a>

    <ul class="nav-links">
      <li><a href="/playground" class={isActive('/playground') ? 'active' : ''}>Playground</a></li>
      <li><a href="/studio" class={isActive('/studio') ? 'active' : ''}>Studio</a></li>

      <li class="nav-dropdown">
        <button class={`nav-dropdown-toggle ${isActive('/how-it-works') ? 'active' : ''}`} aria-haspopup="true">
          How it works ▾
        </button>
        <ul class="nav-dropdown-menu">
          <li><a href="/how-it-works">Overview</a></li>
          <li><a href="/how-it-works/frontend">Frontend Pipeline</a></li>
          <li><a href="/how-it-works/runtime">Runtime Evaluator</a></li>
          <li><a href="/how-it-works/libraries">Libraries</a></li>
          <li><a href="/how-it-works/embedding">Embedding</a></li>
        </ul>
      </li>

      <li class="nav-dropdown">
        <button class={`nav-dropdown-toggle ${isActive('/status') ? 'active' : ''}`} aria-haspopup="true">
          Status ▾
        </button>
        <ul class="nav-dropdown-menu">
          <li><a href="/status">Overview</a></li>
          <li><a href="/status/language">Language Features</a></li>
          <li><a href="/status/stdlib">Standard Library</a></li>
          <li><a href="/status/foundation">Foundation</a></li>
          <li><a href="/status/swiftui">SwiftUI</a></li>
        </ul>
      </li>
    </ul>

    <div class="nav-spacer"></div>

    <a
      href="https://github.com/siuying/tswift"
      target="_blank"
      rel="noopener noreferrer"
      class="nav-github"
      aria-label="tswift on GitHub"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
      </svg>
      GitHub
    </a>
  </div>
</nav>
